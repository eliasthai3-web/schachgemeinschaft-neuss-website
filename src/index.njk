{% macro newsCard(news) %}
<article class="news-item reveal">
  {% if news.data.image %}
  <figure class="news-image">
    <img src="{{ news.data.image }}" alt="{{ news.data.imageAlt or news.data.title }}" />
  </figure>
  {% endif %}
  <div class="news-card-body">
    <time class="news-meta" datetime="{{ news.data.date | dateIso }}">{{ news.data.date | dateDe }}</time>
    <h3><a class="news-title-link" href="{{ news.url }}">{{ news.data.title }}</a></h3>
    <p class="news-summary">{{ news.data.summary }}</p>
    <a class="btn btn-secondary news-read-more" href="{{ news.url }}">Weiterlesen</a>
  </div>
</article>
{% endmacro %}

<header class="topbar">
    <div class="container nav">
      <a href="#top" class="brand">
        <div class="brand-mark">
          <img src="/assets/images/Logo_SGNeuss.jpg" alt="Logo Schachgemeinschaft Neuss e.V." />
        </div>
        <div class="brand-text">
          Schachgemeinschaft Neuss e.V.
          <small>Schach in Neuss · Jugend · Mannschaft · Verein</small>
        </div>
      </a>

      <nav class="nav-links" id="navLinks">
        <a href="#verein">Verein</a>
        <a href="#aktuelles">Aktuelles</a>
        <a href="#geschichte">Geschichte</a>
        <a href="#training">Training</a>
        <a href="#mannschaft">Mannschaft</a>
        <a href="#dokumente">Dokumente</a>
        <a href="#mitglied-werden" class="btn btn-primary">Mitglied werden</a>
      </nav>

      <button class="menu-toggle" id="menuToggle" aria-label="Menü öffnen">☰</button>
    </div>
